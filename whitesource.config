# npm
npm.includeDevDependencies=false

# Python
python.path=python3.12
python.invokePipAsModule=true
python.installVirtualenv=true
python.pipenvDevDependencies=false
python.includePoetryDevDependencies=false

# PHP
php.includeDevDependencies=false

# Maven
maven.runPreStep=true
maven.ignoredScopes=test,provided

# Gradle — narrower and safer than .*compile.*
gradle.ignoredConfigurations=.*[Tt]est.* compileOnly .*CompileOnly

# Go (if applicable)
go.modules.includeTestDependencies=false

# Scan behavior
commandTimeout=7200
showProgressBar=false
excludes=**/rider-examples,**/examples,**/src/test,**/node_modules,**/build,**/target,**/dist,**/.gradle,**/venv,**/.venv,**/__pycache__